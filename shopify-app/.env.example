# Shopify app credentials (Partner Dashboard → Apps → Giulio Geo)
SHOPIFY_API_KEY=bfdee818e5750cdf0a6b699eb914b87e
SHOPIFY_API_SECRET=your_client_secret_here
SCOPES=read_products,write_products,write_content,read_themes,write_themes,write_metafields

# Public URL
# - Local dev: updated automatically by `shopify app dev`
# - Real-store pilot / production: stable public HTTPS origin that matches the linked Shopify app config
SHOPIFY_APP_URL=https://leonie-seo-pilot-web.onrender.com

# Database (same Neon Postgres as Python backend — task 54)
# Required for persistent session storage in pilot/prod. Leave empty only for local dev.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Redis session storage (optional, takes priority over DATABASE_URL when set)
# Avoids a Postgres round-trip on every authenticate.admin() call. Leave empty to
# fall back to Postgres (or SQLite for local dev).
# REDIS_URL=redis://user:password@host:port

# Python backend URL
# - Local dev: http://localhost:8000
# - Render pilot: the public URL of the `leonie-seo-pilot-api` web service
PYTHON_BACKEND_URL=https://leonie-seo-pilot-api.onrender.com

# Internal auth secret — must match INTERNAL_API_SECRET in the Python .env
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_SECRET=your_shared_secret_here

# Optional merchant support chat (bottom-right of the app). Paste the embed URL
# from a free Tawk.to account (Dashboard → Administration → Chat Widget →
# "Direct Chat Link" / embed src), e.g. https://embed.tawk.to/<property>/<widget>.
# Configure online hours + offline message inside Tawk.to. Leave empty to disable.
# LEONIE_SUPPORT_CHAT_SRC=https://embed.tawk.to/xxxxxxxx/xxxxxxxx
