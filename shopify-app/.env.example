# Shopify app credentials (Partner Dashboard → Apps → Léonie SEO)
SHOPIFY_API_KEY=53ff34f2abe2ab7e3a2cd334fbd84db8
SHOPIFY_API_SECRET=your_client_secret_here
SCOPES=read_products,write_products,read_orders

# Public URL
# - Local dev: updated automatically by `shopify app dev`
# - Real-store pilot / production: stable public HTTPS origin that matches the linked Shopify app config
SHOPIFY_APP_URL=https://pilot.example.com

# Database (same Neon Postgres as Python backend — task 54)
# Required for persistent session storage in pilot/prod. Leave empty only for local dev.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Python backend URL
PYTHON_BACKEND_URL=http://localhost:8000

# Internal auth secret — must match INTERNAL_API_SECRET in the Python .env
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_SECRET=your_shared_secret_here
