{%- comment -%}
  Léonie SEO — Collection JSON-LD block
  Renders Schema.org/CollectionPage + BreadcrumbList.
  Add this block to the <head> section via the theme editor on collection templates.
{%- endcomment -%}

{%- if collection -%}
{%- assign shop_url = shop.secure_url | default: shop.url -%}
{%- assign collection_url = shop_url | append: collection.url -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "CollectionPage",
  "name": {{ collection.title | json }},
  "url": {{ collection_url | json }},
  {%- if collection.description != blank -%}
  "description": {{ collection.description | strip_html | truncate: 300 | json }},
  {%- endif -%}
  {%- if collection.image -%}
  "image": {{ collection.image.src | image_url: width: 5760 | prepend: 'https:' | json }},
  {%- endif -%}
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": {{ 'general.breadcrumbs.home' | t | default: 'Accueil' | json }},
        "item": {{ shop_url | json }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }},
        "item": {{ collection_url | json }}
      }
    ]
  }
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "Collection JSON-LD",
  "target": "head",
  "templates": ["collection"]
}
{% endschema %}
