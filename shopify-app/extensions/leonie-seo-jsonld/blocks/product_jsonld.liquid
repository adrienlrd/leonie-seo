{%- comment -%}
  Léonie SEO — Product JSON-LD block
  Renders Schema.org/Product + BreadcrumbList without modifying theme.liquid.
  Add this block to the <head> section via the theme editor on product templates.
{%- endcomment -%}

{%- if product -%}
{%- assign variant = product.selected_or_first_available_variant -%}
{%- assign shop_url = shop.secure_url | default: shop.url -%}
{%- assign product_url = shop_url | append: product.url -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "url": {{ product_url | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ shop.name | json }}
  },
  {%- if product.images.size > 0 -%}
  "image": [
    {%- for image in product.images -%}
      {{ image.src | img_url: 'master' | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  {%- endif -%}
  {%- if variant.sku != blank -%}
  "sku": {{ variant.sku | json }},
  {%- endif -%}
  "offers": {
    "@type": "Offer",
    "priceCurrency": {{ shop.currency | json }},
    "price": {{ variant.price | times: 0.01 }},
    "availability": {%- if product.available -%}"https://schema.org/InStock"{%- else -%}"https://schema.org/OutOfStock"{%- endif -%},
    "url": {{ product_url | json }}
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": {{ 'general.breadcrumbs.home' | t | default: 'Accueil' | json }},
        "item": {{ shop_url | json }}
      }
      {%- if collection -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }},
        "item": {{ shop_url | append: collection.url | json }}
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ product.title | json }},
        "item": {{ product_url | json }}
      }
      {%- else -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ product.title | json }},
        "item": {{ product_url | json }}
      }
      {%- endif -%}
    ]
  }
}
</script>
{%- endif -%}

{% schema %}
{
  "name": "Product JSON-LD",
  "target": "head",
  "limit": 1,
  "templates": ["product"]
}
{% endschema %}
