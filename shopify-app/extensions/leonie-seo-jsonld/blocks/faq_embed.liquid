{%- comment -%}
  Giulio Geo — unified storefront embed
  Controls: visible product FAQ, breadcrumb navigation, and JSON-LD structured data.
  Product JSON-LD stays Shopify-first and enriches from `leonie.schema_facts`
  only when merchant-approved facts have been synced by the app.
{%- endcomment -%}

{%- assign placement = block.settings.placement | default: 'above_footer' -%}
{%- assign enable_faq = true -%}
{%- if block.settings.enable_faq == false -%}
  {%- assign enable_faq = false -%}
{%- endif -%}
{%- assign enable_jsonld = true -%}
{%- if block.settings.enable_jsonld == false -%}
  {%- assign enable_jsonld = false -%}
{%- endif -%}
{%- assign enable_breadcrumb = true -%}
{%- if block.settings.enable_breadcrumb == false -%}
  {%- assign enable_breadcrumb = false -%}
{%- endif -%}
{%- assign bc_sep = block.settings.separator | default: '›' -%}
{%- assign bc_home = 'general.breadcrumbs.home' | t | default: 'Accueil' -%}

{%- comment -%}
  Paid-feature gate: the app sets shop metafield leonie.theme_entitled=false when a
  merchant downgrades. Absent flag = fail-open (existing paid merchants keep rendering).
{%- endcomment -%}
{%- unless shop.metafields.leonie.theme_entitled.value == false -%}

{%- comment -%} ── JSON-LD structured data ─────────────────────────────────── {%- endcomment -%}
{%- if enable_jsonld -%}
  {%- if template contains 'product' and product -%}
    {%- assign variant = product.selected_or_first_available_variant -%}
    {%- assign shop_url = shop.secure_url | default: shop.url -%}
    {%- assign product_url = shop_url | append: product.url -%}
    {%- assign schema_facts = product.metafields.leonie.schema_facts.value -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "url": {{ product_url | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ shop.name | json }}
  },
  {%- if product.images.size > 0 -%}
  "image": [
    {%- for image in product.images -%}
      {{ image.src | image_url: width: 5760 | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  {%- endif -%}
  {%- if variant.sku != blank -%}
  "sku": {{ variant.sku | json }},
  {%- endif -%}
  {%- if schema_facts.materials != blank -%}
  "material": {{ schema_facts.materials | json }},
  {%- endif -%}
  {%- if schema_facts.origins != blank -%}
  "countryOfOrigin": {{ schema_facts.origins | json }},
  {%- endif -%}
  "offers": {
    "@type": "Offer",
    "priceCurrency": {{ shop.currency | json }},
    "price": {{ variant.price | times: 0.01 }},
    "availability": {%- if product.available -%}"https://schema.org/InStock"{%- else -%}"https://schema.org/OutOfStock"{%- endif -%},
    "url": {{ product_url | json }}
  },
  {%- if schema_facts.certifications != blank or schema_facts.warranty != blank or schema_facts.care != blank or schema_facts.dimensions != blank or schema_facts.compatibility != blank or schema_facts.use_cases != blank or schema_facts.selection_criteria != blank -%}
  "additionalProperty": [
    {%- assign property_count = 0 -%}
    {%- if schema_facts.certifications != blank -%}
      {%- if property_count > 0 -%},{%- endif -%}
      {"@type":"PropertyValue","name":"Certifications","value":{{ schema_facts.certifications | json }}}
      {%- assign property_count = property_count | plus: 1 -%}
    {%- endif -%}
    {%- if schema_facts.warranty != blank -%}
      {%- if property_count > 0 -%},{%- endif -%}
      {"@type":"PropertyValue","name":"Warranty","value":{{ schema_facts.warranty | json }}}
      {%- assign property_count = property_count | plus: 1 -%}
    {%- endif -%}
    {%- if schema_facts.care != blank -%}
      {%- if property_count > 0 -%},{%- endif -%}
      {"@type":"PropertyValue","name":"Care","value":{{ schema_facts.care | json }}}
      {%- assign property_count = property_count | plus: 1 -%}
    {%- endif -%}
    {%- if schema_facts.dimensions != blank -%}
      {%- if property_count > 0 -%},{%- endif -%}
      {"@type":"PropertyValue","name":"Dimensions","value":{{ schema_facts.dimensions | json }}}
      {%- assign property_count = property_count | plus: 1 -%}
    {%- endif -%}
    {%- if schema_facts.compatibility != blank -%}
      {%- if property_count > 0 -%},{%- endif -%}
      {"@type":"PropertyValue","name":"Compatibility","value":{{ schema_facts.compatibility | json }}}
      {%- assign property_count = property_count | plus: 1 -%}
    {%- endif -%}
    {%- if schema_facts.use_cases != blank -%}
      {%- if property_count > 0 -%},{%- endif -%}
      {"@type":"PropertyValue","name":"Use cases","value":{{ schema_facts.use_cases | json }}}
      {%- assign property_count = property_count | plus: 1 -%}
    {%- endif -%}
    {%- if schema_facts.selection_criteria != blank -%}
      {%- if property_count > 0 -%},{%- endif -%}
      {"@type":"PropertyValue","name":"Selection criteria","value":{{ schema_facts.selection_criteria | json }}}
    {%- endif -%}
  ],
  {%- endif -%}
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": {{ bc_home | json }},
        "item": {{ shop_url | json }}
      }
      {%- if collection -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }},
        "item": {{ shop_url | append: collection.url | json }}
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ product.title | json }},
        "item": {{ product_url | json }}
      }
      {%- else -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ product.title | json }},
        "item": {{ product_url | json }}
      }
      {%- endif -%}
    ]
  }
}
</script>
  {%- elsif template contains 'collection' and collection -%}
    {%- assign shop_url = shop.secure_url | default: shop.url -%}
    {%- assign collection_url = shop_url | append: collection.url -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "CollectionPage",
  "name": {{ collection.title | json }},
  "url": {{ collection_url | json }},
  {%- if collection.description != blank -%}
  "description": {{ collection.description | strip_html | truncate: 300 | json }},
  {%- endif -%}
  {%- if collection.image -%}
  "image": {{ collection.image.src | image_url: width: 5760 | prepend: 'https:' | json }},
  {%- endif -%}
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": {{ bc_home | json }},
        "item": {{ shop_url | json }}
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }},
        "item": {{ collection_url | json }}
      }
    ]
  }
}
</script>
  {%- elsif template contains 'article' and article -%}
    {%- assign shop_url = shop.secure_url | default: shop.url -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":{{ bc_home | json }},"item":{{ shop_url | json }}},
    {"@type":"ListItem","position":2,"name":{{ blog.title | json }},"item":{{ blog.url | prepend: shop_url | json }}},
    {"@type":"ListItem","position":3,"name":{{ article.title | json }},"item":{{ article.url | prepend: shop_url | json }}}
  ]
}
</script>
  {%- elsif template contains 'blog' and blog -%}
    {%- assign shop_url = shop.secure_url | default: shop.url -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":{{ bc_home | json }},"item":{{ shop_url | json }}},
    {"@type":"ListItem","position":2,"name":{{ blog.title | json }},"item":{{ blog.url | prepend: shop_url | json }}}
  ]
}
</script>
  {%- elsif template.name == 'index' -%}
    {%- assign shop_url = shop.secure_url | default: shop.url -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ shop.name | json }},
  "url": {{ shop_url | json }}
  {%- if shop.email != blank -%}
  ,"email": {{ shop.email | json }}
  {%- endif -%}
  {%- if shop.phone != blank -%}
  ,"telephone": {{ shop.phone | json }}
  {%- endif -%}
  {%- if shop.address.country_code != blank -%}
  ,"address": {
    "@type": "PostalAddress",
    {%- if shop.address.street != blank -%}
    "streetAddress": {{ shop.address.street | json }},
    {%- endif -%}
    {%- if shop.address.city != blank -%}
    "addressLocality": {{ shop.address.city | json }},
    {%- endif -%}
    {%- if shop.address.zip != blank -%}
    "postalCode": {{ shop.address.zip | json }},
    {%- endif -%}
    "addressCountry": {{ shop.address.country_code | json }}
  }
  {%- endif -%}
}
</script>
  {%- endif -%}
{%- endif -%}

{%- comment -%} ── Visible breadcrumb navigation ──────────────────────────── {%- endcomment -%}
{%- if enable_breadcrumb -%}
  {%- assign shop_url = shop.secure_url | default: shop.url -%}
  {%- assign bc_json = '' -%}

  {%- if template contains 'product' and product -%}
    {%- assign bc_collection = collection | default: product.collections.first -%}
    {%- capture bc_json -%}[{"label":{{ bc_home | json }},"url":{{ shop_url | json }}}{% if bc_collection %},{"label":{{ bc_collection.title | json }},"url":{{ bc_collection.url | prepend: shop_url | json }}}{% endif %},{"label":{{ product.title | json }},"url":{{ product.url | prepend: shop_url | json }},"current":true}]{%- endcapture -%}
  {%- elsif template contains 'collection' and collection -%}
    {%- capture bc_json -%}[{"label":{{ bc_home | json }},"url":{{ shop_url | json }}},{"label":{{ collection.title | json }},"url":{{ collection.url | prepend: shop_url | json }},"current":true}]{%- endcapture -%}
  {%- elsif template contains 'article' and article -%}
    {%- capture bc_json -%}[{"label":{{ bc_home | json }},"url":{{ shop_url | json }}},{"label":{{ blog.title | json }},"url":{{ blog.url | prepend: shop_url | json }}},{"label":{{ article.title | json }},"url":{{ article.url | prepend: shop_url | json }},"current":true}]{%- endcapture -%}
  {%- elsif template contains 'blog' and blog -%}
    {%- capture bc_json -%}[{"label":{{ bc_home | json }},"url":{{ shop_url | json }}},{"label":{{ blog.title | json }},"url":{{ blog.url | prepend: shop_url | json }},"current":true}]{%- endcapture -%}
  {%- elsif template contains 'page' and page -%}
    {%- capture bc_json -%}[{"label":{{ bc_home | json }},"url":{{ shop_url | json }}},{"label":{{ page.title | json }},"url":{{ page.url | prepend: shop_url | json }},"current":true}]{%- endcapture -%}
  {%- endif -%}

  {%- if bc_json != blank -%}

<template id="leonie-bc-tpl" data-sep="{{ bc_sep | escape }}">
  <nav class="leonie-bc" aria-label="Breadcrumb">
    <ol class="leonie-bc__list" itemscope itemtype="https://schema.org/BreadcrumbList"></ol>
  </nav>
</template>
<script id="leonie-bc-data" type="application/json">{{ bc_json | strip }}</script>

<script>
(function () {
  var tpl = document.getElementById('leonie-bc-tpl');
  var dataEl = document.getElementById('leonie-bc-data');
  if (!tpl || !dataEl) return;

  // Skip if the theme already renders a visible breadcrumb
  var EXISTING = [
    '.breadcrumb', '.breadcrumbs', '.bread-crumb', '.bc-crumbs',
    '[aria-label="breadcrumb"]', '[aria-label="Breadcrumb"]',
    'nav[class*="breadcrumb"]', 'ol[class*="breadcrumb"]'
  ];
  if (EXISTING.some(function (s) { return document.querySelector(s); })) {
    tpl.remove(); dataEl.remove(); return;
  }

  var items;
  try { items = JSON.parse(dataEl.textContent || '[]'); } catch (e) { return; }
  if (!Array.isArray(items) || items.length < 2) return;

  function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  var sep = tpl.dataset.sep || '›';
  var nav = tpl.content.cloneNode(true);
  var ol = nav.querySelector('.leonie-bc__list');
  ol.style.setProperty('--leonie-bc-sep', '"' + sep + '"');

  items.forEach(function (item, i) {
    var li = document.createElement('li');
    li.className = 'leonie-bc__item';
    li.setAttribute('itemprop', 'itemListElement');
    li.setAttribute('itemscope', '');
    li.setAttribute('itemtype', 'https://schema.org/ListItem');
    var pos = '<meta itemprop="position" content="' + (i + 1) + '">';
    if (item.current) {
      li.innerHTML = '<span class="leonie-bc__current" itemprop="name">' + esc(item.label) + '</span>' + pos;
    } else {
      li.innerHTML = '<a class="leonie-bc__link" href="' + esc(item.url) + '" itemprop="item"><span itemprop="name">' + esc(item.label) + '</span></a>' + pos;
    }
    ol.appendChild(li);
  });

  // Insert INSIDE the first .page-width container so we inherit the theme's
  // horizontal padding naturally. Fall back to before the first section or
  // prepend to main — and add our own padding in those cases.
  var INSIDE = [
    '#MainContent .page-width', '#main-content .page-width',
    'main .page-width', '.main-page-content .page-width',
    '#MainContent .container', 'main .wrapper',
  ];
  var BEFORE = [
    '#MainContent > *:first-child', '#main-content > *:first-child',
    'main > .shopify-section:first-child', 'main > *:first-child',
  ];
  var CONTAINERS = ['main', '[role="main"]', '#MainContent'];

  var wrapper = document.createElement('div');
  wrapper.className = 'leonie-bc-wrapper';
  wrapper.appendChild(nav);

  var inserted = false;
  for (var i = 0; i < INSIDE.length; i++) {
    var el = document.querySelector(INSIDE[i]);
    if (el) {
      el.insertBefore(wrapper, el.firstChild);
      inserted = true; break;
    }
  }
  if (!inserted) {
    for (var j = 0; j < BEFORE.length; j++) {
      var el2 = document.querySelector(BEFORE[j]);
      if (el2 && el2.parentNode) {
        wrapper.dataset.outside = '1';
        el2.parentNode.insertBefore(wrapper, el2);
        inserted = true; break;
      }
    }
  }
  if (!inserted) {
    for (var k = 0; k < CONTAINERS.length; k++) {
      var el3 = document.querySelector(CONTAINERS[k]);
      if (el3) { el3.insertBefore(wrapper, el3.firstChild); inserted = true; break; }
    }
  }

  tpl.remove();
  dataEl.remove();
})();
</script>

  {%- endif -%}
{%- endif -%}

{%- comment -%} ── Visible FAQ widget ─────────────────────────────────────── {%- endcomment -%}
{%- if enable_faq and placement != 'none' and template contains 'product' and product and product.metafields.leonie.faq -%}
{%- assign faq_entries = product.metafields.leonie.faq.value -%}
{%- if faq_entries.size > 0 -%}

<template id="leonie-faq-template" data-placement="{{ placement | escape }}">
  <section class="leonie-faq" aria-labelledby="leonie-faq-heading">
    <h2 id="leonie-faq-heading" class="leonie-faq__heading">
      {{ block.settings.heading | default: 'Questions fréquentes' }}
    </h2>
    <div class="leonie-faq__list">
      {%- for entry in faq_entries -%}
        {%- assign question = entry.q | default: entry.question -%}
        {%- assign answer = entry.a | default: entry.answer -%}
        {%- if question != blank and answer != blank -%}
          <details class="leonie-faq__item">
            <summary class="leonie-faq__question">
              <span>{{ question }}</span>
              <svg class="leonie-faq__icon" aria-hidden="true" viewBox="0 0 16 16" width="14" height="14">
                <path d="M4 6l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="leonie-faq__answer">{{ answer }}</div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>
</template>

<script>
  (function () {
    var template = document.getElementById('leonie-faq-template');
    if (!template) return;

    var placement = template.dataset.placement || 'above_footer';
    var content = template.content.cloneNode(true);

    // Avoid duplicate render when the in-section block is also active
    if (document.querySelector('.leonie-faq')) { template.remove(); return; }

    function productSection() {
      return document.querySelector(
        '[id^="shopify-section-main-product"], ' +
        '[id^="shopify-section-template--"][id*="product"], ' +
        '#MainProduct, .product-section, section.product, [data-section-type="product"]'
      );
    }

    function aboveFooterTarget() {
      var firstFooterSection = document.querySelector('.shopify-section-group-footer-group');
      if (firstFooterSection) {
        var wrapper = firstFooterSection.parentElement;
        if (wrapper) {
          var label = ((wrapper.className || '') + ' ' + (wrapper.id || '')).toLowerCase();
          if (label.indexOf('footer') !== -1) return wrapper;
        }
        return firstFooterSection;
      }
      var group = document.querySelector(
        '[id^="shopify-section-group-footer"], [id^="shopify-section-footer-group"]'
      );
      if (group) return group;
      var main = document.querySelector('main, [role="main"], #MainContent, .main-content');
      if (main && main.parentNode) {
        var next = main.nextElementSibling;
        while (next && (next.tagName === 'SCRIPT' || next.tagName === 'STYLE' || next.tagName === 'NOSCRIPT')) {
          next = next.nextElementSibling;
        }
        if (next) return next;
      }
      var f = document.querySelector('footer, [role="contentinfo"]');
      if (f) return f.closest('[id^="shopify-section-"]') || f;
      return null;
    }

    var inserted = false;
    var section, target;

    if (placement === 'above_footer') {
      target = aboveFooterTarget();
      if (target && target.parentNode) { target.parentNode.insertBefore(content, target); inserted = true; }
    } else {
      section = productSection();
      if (section && section.parentNode) {
        section.parentNode.insertBefore(content, section.nextSibling);
        inserted = true;
      }
    }

    if (!inserted) {
      target = aboveFooterTarget();
      if (target && target.parentNode) { target.parentNode.insertBefore(content, target); inserted = true; }
    }
    if (!inserted) document.body.appendChild(content);

    template.remove();
  })();
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for entry in faq_entries -%}
      {%- assign q = entry.q | default: entry.question -%}
      {%- assign a = entry.a | default: entry.answer -%}
      {%- if q != blank and a != blank -%}
      {
        "@type": "Question",
        "name": {{ q | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ a | json }}
        }
      }{% unless forloop.last %},{% endunless %}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>

{%- endif -%}
{%- endif -%}

{%- endunless -%}

{%- style -%}
.leonie-bc-wrapper {
  width: 100%;
  box-sizing: border-box;
}
.leonie-bc-wrapper[data-outside] {
  padding-left: var(--page-margin, 1rem);
  padding-right: var(--page-margin, 1rem);
}
.leonie-bc {
  font-size: 0.8125em;
  line-height: 1.4;
  padding: 0.625em 0;
  color: inherit;
  font-family: inherit;
  opacity: 0.75;
}
.leonie-bc * { box-sizing: border-box; }
.leonie-bc__list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}
.leonie-bc__item { display: flex; align-items: center; }
.leonie-bc__item + .leonie-bc__item::before {
  content: var(--leonie-bc-sep, "\203a");
  padding: 0 0.4em;
  opacity: 0.45;
}
.leonie-bc__link { color: inherit; text-decoration: none; }
.leonie-bc__link:hover,
.leonie-bc__link:focus-visible { text-decoration: underline; }
.leonie-bc__current { opacity: 0.6; }
.leonie-faq {
  display: block;
  box-sizing: border-box;
  width: 100%;
  max-width: 760px;
  margin: 2.5rem auto;
  padding: 0 1.5rem;
  font-family: inherit;
  color: inherit;
}
.leonie-faq * { box-sizing: border-box; }
.leonie-faq__heading {
  font-size: 1.25rem;
  font-weight: 600;
  margin: 0 0 1.25rem;
  letter-spacing: -0.01em;
}
.leonie-faq__list {
  width: 100%;
  border-top: 1px solid rgba(0, 0, 0, 0.08);
}
.leonie-faq__item {
  display: block;
  width: 100%;
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
}
.leonie-faq__question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  width: 100%;
  padding: 1rem 0;
  font-weight: 500;
  font-size: 1rem;
  cursor: pointer;
  list-style: none;
  line-height: 1.4;
}
.leonie-faq__question > span { flex: 1 1 auto; min-width: 0; }
.leonie-faq__question::-webkit-details-marker { display: none; }
.leonie-faq__question::marker { content: ''; }
.leonie-faq__question:hover { opacity: 0.75; }
.leonie-faq__icon {
  flex-shrink: 0;
  transition: transform 0.2s ease;
  opacity: 0.6;
}
.leonie-faq__item[open] .leonie-faq__icon { transform: rotate(180deg); }
.leonie-faq__answer {
  width: 100%;
  padding: 0 0 1rem;
  font-size: 0.95rem;
  line-height: 1.6;
  opacity: 0.85;
  overflow-wrap: break-word;
  word-wrap: break-word;
}
@media (prefers-color-scheme: dark) {
  .leonie-faq__list,
  .leonie-faq__item { border-color: rgba(255, 255, 255, 0.12); }
}
{%- endstyle -%}

{% schema %}
{
  "name": "Giulio Geo",
  "target": "body",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_breadcrumb",
      "label": "Afficher le fil d'ariane",
      "default": true
    },
    {
      "type": "select",
      "id": "separator",
      "label": "Séparateur du fil d'ariane",
      "options": [
        { "value": "›", "label": "›  chevron" },
        { "value": "/", "label": "/  slash" },
        { "value": "·", "label": "·  point médian" },
        { "value": "→", "label": "→  flèche" }
      ],
      "default": "›"
    },
    {
