{%- comment -%}
  Léonie SEO — FAQ embed (App Embed Block)
  Auto-injected on product pages, just before the footer by default.
  Renders the FAQ stored in the `leonie.faq` metafield + FAQPage JSON-LD.
  Activate via Theme Editor → App embeds.
{%- endcomment -%}

{%- if template contains 'product' and product and product.metafields.leonie.faq -%}
{%- assign faq_entries = product.metafields.leonie.faq.value -%}
{%- if faq_entries.size > 0 -%}

<template
  id="leonie-faq-template"
  data-selector="{{ block.settings.insertion_selector | default: '' | escape }}"
  data-position="{{ block.settings.insertion_position | default: 'before' | escape }}"
>
  <section class="leonie-faq" aria-labelledby="leonie-faq-heading">
    <h2 id="leonie-faq-heading" class="leonie-faq__heading">
      {{ block.settings.heading | default: 'Questions fréquentes' }}
    </h2>
    <div class="leonie-faq__list">
      {%- for entry in faq_entries -%}
        {%- assign question = entry.q | default: entry.question -%}
        {%- assign answer = entry.a | default: entry.answer -%}
        {%- if question != blank and answer != blank -%}
          <details class="leonie-faq__item">
            <summary class="leonie-faq__question">
              <span>{{ question }}</span>
              <svg class="leonie-faq__icon" aria-hidden="true" viewBox="0 0 16 16" width="14" height="14">
                <path d="M4 6l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="leonie-faq__answer">{{ answer }}</div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </section>
</template>

<script>
  (function () {
    var template = document.getElementById('leonie-faq-template');
    if (!template) return;

    var customSelector = template.dataset.selector;
    var position = template.dataset.position || 'before';
    var content = template.content.cloneNode(true);
    var inserted = false;

    function insertAt(el, frag, pos) {
      if (!el || !el.parentNode) return false;
      if (pos === 'after') {
        el.parentNode.insertBefore(frag, el.nextSibling);
      } else if (pos === 'append') {
        el.appendChild(frag);
      } else {
        el.parentNode.insertBefore(frag, el);
      }
      return true;
    }

    // 1) Custom CSS selector (merchant-defined) takes priority
    if (customSelector) {
      var customEl = document.querySelector(customSelector);
      if (insertAt(customEl, content, position)) inserted = true;
    }

    // 2) Auto: insert just before the footer (most reliable across themes)
    if (!inserted) {
      var footer = document.querySelector(
        'footer, [role="contentinfo"], .footer, #footer, .site-footer, ' +
        '[id^="shopify-section-footer"], [id^="shopify-section-sections--"][id*="footer"]'
      );
      if (insertAt(footer, content, 'before')) inserted = true;
    }

    // 3) Fallback: end of main content
    if (!inserted) {
      var main = document.querySelector('main, [role="main"], #MainContent, .main-content');
      if (main) {
        main.appendChild(content);
        inserted = true;
      }
    }

    // 4) Last resort
    if (!inserted) document.body.appendChild(content);

    template.remove();
  })();
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for entry in faq_entries -%}
      {%- assign q = entry.q | default: entry.question -%}
      {%- assign a = entry.a | default: entry.answer -%}
      {%- if q != blank and a != blank -%}
      {
        "@type": "Question",
        "name": {{ q | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ a | json }}
        }
      }{% unless forloop.last %},{% endunless %}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>

{%- style -%}
.leonie-faq {
  margin: 2.5rem auto;
  font-family: inherit;
  color: inherit;
  max-width: 760px;
  padding: 0 1.5rem;
}
.leonie-faq__heading {
  font-size: 1.25rem;
  font-weight: 600;
  margin: 0 0 1.25rem;
  letter-spacing: -0.01em;
}
.leonie-faq__list {
  border-top: 1px solid rgba(0, 0, 0, 0.08);
}
.leonie-faq__item {
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
}
.leonie-faq__question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 1rem 0;
  font-weight: 500;
  font-size: 1rem;
  cursor: pointer;
  list-style: none;
  line-height: 1.4;
}
.leonie-faq__question::-webkit-details-marker { display: none; }
.leonie-faq__question::marker { content: ''; }
.leonie-faq__question:hover { opacity: 0.75; }
.leonie-faq__icon {
  flex-shrink: 0;
  transition: transform 0.2s ease;
  opacity: 0.6;
}
.leonie-faq__item[open] .leonie-faq__icon { transform: rotate(180deg); }
.leonie-faq__answer {
  padding: 0 0 1rem;
  font-size: 0.95rem;
  line-height: 1.6;
  opacity: 0.85;
}
@media (prefers-color-scheme: dark) {
  .leonie-faq__list,
  .leonie-faq__item { border-color: rgba(255, 255, 255, 0.12); }
}
{%- endstyle -%}

{%- endif -%}
{%- endif -%}

{% schema %}
{
  "name": "FAQ produit (Léonie)",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre du bloc FAQ",
      "default": "Questions fréquentes"
    },
    {
      "type": "header",
      "content": "Emplacement"
    },
    {
      "type": "paragraph",
      "content": "Par défaut, la FAQ apparaît automatiquement juste au-dessus du footer. Pour la placer ailleurs, indiquez un sélecteur CSS d'un élément de votre thème (ex : .product-recommendations)."
    },
    {
      "type": "text",
      "id": "insertion_selector",
      "label": "Sélecteur CSS personnalisé",
      "info": "Laissez vide pour le placement automatique avant le footer."
    },
    {
      "type": "select",
      "id": "insertion_position",
      "label": "Position par rapport à ce sélecteur",
      "options": [
        { "value": "before", "label": "Avant l'élément" },
        { "value": "after", "label": "Après l'élément" },
        { "value": "append", "label": "À l'intérieur (en bas)" }
      ],
      "default": "before"
    }
  ]
}
{% endschema %}
