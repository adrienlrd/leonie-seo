# Tenant
TENANT_ID=leoniedelacroix

# Shopify
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Cloud (Search Console + GA4) — OAuth user flow
GOOGLE_OAUTH_CLIENT_PATH=./oauth_client.json
GOOGLE_OAUTH_TOKEN_PATH=./token.json
# Optional for hosted app mode: paste the OAuth web client JSON instead of using a file.
# GOOGLE_OAUTH_CLIENT_CONFIG='{"web":{...}}'
# GOOGLE_OAUTH_REDIRECT_URI=https://leonie-seo-pilot-api.onrender.com/api/google/gsc/callback
# GOOGLE_OAUTH_STATE_SECRET=  # defaults to INTERNAL_API_SECRET when omitted
GA4_PROPERTY_ID=properties/XXXXXXXXX

# PageSpeed Insights
PAGESPEED_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxx

# Ahrefs Webmaster Tools
# AHREFS_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# Optional competitor crawl for market analysis.
# Disabled by default. Uses DataForSEO SERP URLs only, respects robots.txt,
# rate-limits by domain, caches extracted structural features, and never stores HTML.
COMPETITOR_CRAWL_ENABLED=false
COMPETITOR_CRAWL_MAX_URLS_PER_PRODUCT=3
COMPETITOR_CRAWL_MAX_URLS_PER_RUN=50
COMPETITOR_CRAWL_TIMEOUT_SECONDS=12
COMPETITOR_CRAWL_THROTTLE_SECONDS=1.5
COMPETITOR_CRAWL_CACHE_TTL_DAYS=14
COMPETITOR_CRAWL_USER_AGENT="LeonieSEOBot/0.1 (+SEO/GEO analysis; contact configurable)"

# Licence (productisation)
# LICENSE_SECRET=  # Vendeur : secret de signature des clés (garder privé)
# LEONIE_API_KEY=  # Client  : clé reçue du vendeur (LEO-xxxx...)

# Phase 6 — Base de données (Neon Postgres)
# Laisser vide → SQLite local (dev/tests). Renseigner pour Neon en production.
# Format : postgresql://user:password@host/dbname?sslmode=require
# DATABASE_URL=

# Phase 6 — Secret interne Remix ↔ Python (task 57)
# Partagé entre shopify-app/.env et ce fichier. Générer via :
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# INTERNAL_API_SECRET=

# Phase 5 — App Shopify publique / pilote réel (OAuth)
# SHOPIFY_CLIENT_ID=     # Partner Portal → Apps → ton app → Client ID
# SHOPIFY_CLIENT_SECRET= # Partner Portal → Apps → ton app → Client Secret
# SHOPIFY_SCOPES=read_products,write_products,read_orders,read_themes,write_themes
# APP_URL=https://pilot.leoniedelacroix.com  # Public HTTPS base URL for OAuth callbacks in pilot/prod
#
# Master key — encrypts Shopify access tokens at rest (REQUIRED in prod).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# LEONIE_MASTER_KEY=
#
# CORS origins (comma-separated). Default: localhost dev ports.
# CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
#
# Auth toggle: use "true" for any public pilot/prod backend exposed beyond localhost.
# LEONIE_REQUIRE_SESSION_TOKEN=true
#
# Billing mode. Use "disabled" for the real-store pilot until paid flows are
# intentionally tested; use "live" only for production billing.
# LEONIE_BILLING_MODE=disabled
#
# Pilot safety. Use "true" for the real-store pilot: live Shopify writes are
# blocked even if a caller sends dry_run=false. Dry-runs and read-only Shopify
# reads still work.
# LEONIE_PILOT_SAFE_MODE=true
